<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/cute"
    tools:context=".MainActivity"
    android:id="@+id/rooot">

    <RelativeLayout
        android:id="@+id/relativeLayout2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:background="@color/blue"
        />




    <TextView
        android:id="@+id/texty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        android:textSize="30dp"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.167" />

    <com.example.myapplication4.CustomBackground
        android:id="@+id/usernameBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"


        >

        <com.example.myapplication4.TextInputWithBackground
            android:id="@+id/usernameField"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"


            app:layout_constraintEnd_toEndOf="parent" />
    </com.example.myapplication4.CustomBackground>

    <TextView
        android:id="@+id/usernameFieldLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="username:"
        android:textColor="@color/white"
        app:layout_constraintRight_toLeftOf="@id/usernameBackground"
        app:layout_constraintTop_toTopOf="@id/usernameBackground"
        />






    <com.example.myapplication4.CustomBackground
        android:id="@+id/passwordBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/usernameBackground"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"


        >

        <com.example.myapplication4.TextInputWithBackground
            android:id="@+id/passwordField"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:inputType="textPassword"


            app:layout_constraintEnd_toEndOf="parent" />
    </com.example.myapplication4.CustomBackground>

    <TextView
        android:id="@+id/passwordFieldLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="password:"
        android:textColor="@color/white"
        app:layout_constraintRight_toLeftOf="@id/passwordBackground"
        app:layout_constraintTop_toTopOf="@id/passwordBackground"

        />
    <Button
        android:id="@+id/loginButton"
        android:layout_width="128dp"
        android:layout_height="67dp"
        android:layout_marginBottom="164dp"
        android:text="Login"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />



    <TextView
        android:id="@+id/OrRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="      or\nregister"
        app:layout_constraintTop_toBottomOf="@id/loginButton"
        app:layout_constraintLeft_toLeftOf="@id/loginButton"
        app:layout_constraintRight_toRightOf="@id/loginButton"
        android:textColor="@color/white"
        android:layout_marginBottom="10dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>