<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".UsersMenu"
    >
    <RelativeLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="@drawable/round_bubble"
        app:layout_constraintTop_toBottomOf="@id/UsersText"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_margin="20dp"
        
        >
        <ImageView
            android:id="@+id/search_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/people_24"
            android:layout_marginLeft="5dp"
            
            />
        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toRightOf="@id/search_icon"
            android:backgroundTint="@color/white"
            android:layout_alignParentEnd="true"/>
            
        
    </RelativeLayout>
        
    <TextView
        android:id="@+id/UsersText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginLeft="10dp"
        android:text="Users"
        android:textColor="@color/white"
        android:textSize="20sp"/>

    <ScrollView
        android:id="@+id/userScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="1"
        app:layout_constraintTop_toBottomOf="@+id/search_bar"
        android:layout_marginTop="5dp"
        app:layout_constraintLeft_toLeftOf="parent">

        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <include layout="@layout/menu_profile_placeholder"/>
        </LinearLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>